{
  "name": "proto-diagram-docs",
  "version": "0.1.0",
  "description": "Generate static documentation sites with SVG diagrams from Protocol Buffer definitions",
  "author": "roomelephant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/room-elephant/proto-diagram-docs.git"
  },
  "homepage": "https://github.com/room-elephant/proto-diagram-docs",
  "bugs": {
    "url": "https://github.com/room-elephant/proto-diagram-docs/issues"
  },
  "bin": {
    "proto-diagram-docs": "bin/proto-diagram-docs.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "test": "jest --testPathIgnorePatterns=e2e --testPathIgnorePatterns=integration",
    "test:integration": "jest test/integration.test.js",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:integration && npm run test:e2e"
  },
  "keywords": [
    "protobuf",
    "protocol-buffers",
    "documentation",
    "graphviz",
    "diagrams",
    "protodot",
    "static-site",
    "svg"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^30.3.0"
  }
}
